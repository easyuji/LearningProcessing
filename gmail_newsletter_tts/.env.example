# Gmail IMAP（アプリパスワード認証）
GMAIL_ADDRESS=easyuji@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NEWSLETTER_LABEL=newsletter
PROCESSED_LABEL=newsletter-tts-done

# TTS音声（Edge TTS = Microsoft製、無料・APIキー不要）
# 女性: ja-JP-NanamiNeural  /  男性: ja-JP-KeitaNeural
TTS_VOICE=ja-JP-NanamiNeural

# Claude API（スクリプト変換用・未設定時はスキップ）
# https://console.anthropic.com/settings/keys でAPIキーを取得
ANTHROPIC_API_KEY=sk-ant-ここにAPIキーを貼る

# GitHub Personal Access Token（repoスコープ）
GITHUB_TOKEN=ghp_ここにトークンを貼る
GITHUB_REPO=easyuji/LearningProcessing
GITHUB_RELEASE_TAG=podcast-mp3s

# Podcast設定
PODCAST_TITLE=My Newsletter Podcast
PODCAST_DESCRIPTION=Gmailのメルマガを音声で聴く
PODCAST_AUTHOR=Yuji
PODCAST_BASE_URL=https://easyuji.github.io/LearningProcessing
PODCAST_FEED_PATH=docs/podcast/feed.xml
